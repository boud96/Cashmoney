{
  "name": "cashmoney-desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Electron shell for the Cashmoney app.",
  "main": "main.js",
  "scripts": {
    "dist": "electron-builder --win --x64",
    "pack": "electron-builder --dir --win --x64",
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "local.cashmoney.desktop",
    "productName": "Cashmoney",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/cashmoney-backend",
        "to": "backend"
      },
      {
        "from": "../backend/finance/static/favicon.ico",
        "to": "favicon.ico"
      }
    ],
    "win": {
      "icon": "../backend/finance/static/favicon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "../backend/finance/static/favicon.ico",
      "uninstallerIcon": "../backend/finance/static/favicon.ico"
    }
  }
}
